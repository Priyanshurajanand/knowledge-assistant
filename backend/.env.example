# App configuration
ENVIRONMENT=development
CORS_ORIGINS=http://localhost:4200,http://127.0.0.1:4200,http://localhost

# PostgreSQL connection string (asyncpg driver required)
DATABASE_URL=postgresql+asyncpg://postgres:postgres@localhost:5432/knowledge_assistant

# JWT Security
JWT_SECRET=generate-a-long-random-string-for-jwt-signing

# Qdrant Cloud settings
QDRANT_URL=https://your-qdrant-cluster-url.aws.cloud.qdrant.io
QDRANT_API_KEY=your-qdrant-api-key

# LLM Providers API Keys
OPENAI_API_KEY=your-openai-api-key
GEMINI_API_KEY=your-gemini-api-key
ANTHROPIC_API_KEY=your-anthropic-api-key
GROQ_API_KEY=your-groq-api-key

# Storage options
UPLOAD_DIR=storage/documents
MAX_UPLOAD_SIZE_BYTES=15728640
